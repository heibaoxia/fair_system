# Copy this file to .env before filling in real values.

# Base URL used to build clickable email verification links.
FAIR_AUTH_VERIFY_URL_BASE=http://127.0.0.1:8000/login

# QQ 邮箱 SMTP 配置（推荐本地测试先用这一套）。
# 注意：FAIR_SMTP_PASSWORD 需要填写 QQ 邮箱 SMTP 授权码，不是邮箱登录密码。
FAIR_SMTP_HOST=smtp.qq.com
FAIR_SMTP_PORT=465
FAIR_EMAIL_FROM=1138723235@qq.com
FAIR_SMTP_USERNAME=1138723235@qq.com
FAIR_SMTP_PASSWORD=atcmxhqykadrgdbi

# 传输选项。
FAIR_SMTP_USE_TLS=false
FAIR_SMTP_USE_SSL=true
FAIR_SMTP_TIMEOUT_SECONDS=10
